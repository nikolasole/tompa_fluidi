Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"joukowski", "[", "c_", "]"}], "[", 
   RowBox[{"{", 
    RowBox[{"x_", ",", "y_"}], "}"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"x", ",", "y"}], "}"}], "+", 
   RowBox[{
    FractionBox[
     SuperscriptBox["c", "2"], 
     RowBox[{
      SuperscriptBox["x", "2"], "+", 
      SuperscriptBox["y", "2"]}]], 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{"-", "y"}]}], "}"}]}]}]}]], "Input",
 TaggingRules->{},
 InitializationCell->True,
 CellChangeTimes->{{3.657539166109869*^9, 3.65753916785708*^9}},
 CellID->133226375,ExpressionUUID->"2300bb7c-816a-425c-9e54-57ad7eb9b3c7"]
}, Closed]],

