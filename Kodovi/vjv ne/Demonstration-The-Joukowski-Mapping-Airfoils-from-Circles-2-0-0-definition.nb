Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"radius", "=", 
        RowBox[{"Max", "[", 
         RowBox[{
          RowBox[{"Norm", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"1", ",", "0"}], "}"}], "-", "center"}], "]"}], ",", 
          RowBox[{"Norm", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "1"}], ",", "0"}], "}"}], "-", "center"}], "]"}]}],
          "]"}]}], ",", "circle"}], "}"}], ",", 
     RowBox[{
      RowBox[{"circle", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"radius", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Cos", "[", "#", "]"}], ",", 
            RowBox[{"Sin", "[", "#", "]"}]}], "}"}]}], "+", "center"}], 
        "&"}]}], ";", 
      RowBox[{"ParametricPlot", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"circle", "[", "\[Theta]", "]"}], ",", 
          RowBox[{
           RowBox[{"joukowski", "[", "1", "]"}], "[", 
           RowBox[{"circle", "[", "\[Theta]", "]"}], "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"\[Theta]", ",", "0", ",", 
          RowBox[{"2", "\[Pi]"}]}], "}"}], ",", 
        RowBox[{"PlotRange", "\[Rule]", "2.5"}], ",", 
        RowBox[{"Epilog", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"AbsolutePointSize", "[", "10", "]"}], ",", "Blue", ",", 
           RowBox[{"Point", "[", 
            RowBox[{"{", 
             RowBox[{"1", ",", "0"}], "}"}], "]"}], ",", 
           RowBox[{"Point", "[", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "1"}], ",", "0"}], "}"}], "]"}], ",", "Red", ",", 
           RowBox[{"Circle", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"-", "0.2"}], ",", "0.2"}], "}"}], ",", "0.08"}], 
            "]"}], ",", 
           RowBox[{"Circle", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"-", "0.2"}], ",", "0.2"}], "}"}], ",", "0.05"}], 
            "]"}], ",", 
           RowBox[{"Circle", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"-", "0.2"}], ",", "0.2"}], "}"}], ",", "0.02"}], 
            "]"}], ",", 
           RowBox[{"Line", "[", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{"-", "0.2"}], ",", "0.1"}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"-", "0.2"}], ",", "0.3"}], "}"}]}], "}"}], "]"}], 
           ",", 
           RowBox[{"Line", "[", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{"-", "0.3"}], ",", "0.2"}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"-", "0.1"}], ",", "0.2"}], "}"}]}], "}"}], "]"}]}], 
          "}"}]}], ",", 
        RowBox[{"PlotStyle", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"Thick", ",", "Blue"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"Thick", ",", "Red"}], "}"}]}], "}"}]}], ",", 
        RowBox[{"ImageSize", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"480", ",", "480"}], "}"}]}]}], "]"}]}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"center", ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "0"}], "}"}]}], "}"}], ",", "Locator"}], "}"}], ",", 
   RowBox[{"SaveDefinitions", "\[Rule]", "True"}]}], "]"}]], "Input",
 TaggingRules->{},
 CellChangeTimes->{
  3.657539200820953*^9, 3.657539830660753*^9, {3.657898373378263*^9, 
   3.657898415881116*^9}},
 CellID->847036161,ExpressionUUID->"a39032fb-b325-4cdc-b54e-6a54eec31843"],

Cell[BoxData[
 TagBox[
  StyleBox[
   DynamicModuleBox[{$CellContext`center$$ = {0, 0}, Typeset`show$$ = True, 
    Typeset`bookmarkList$$ = {}, Typeset`bookmarkMode$$ = "Menu", 
    Typeset`animator$$, Typeset`animvar$$ = 1, Typeset`name$$ = 
    "\"untitled\"", Typeset`specs$$ = {{{
       Hold[$CellContext`center$$], {0, 0}}, Automatic}}, Typeset`size$$ = {
    480., {237.134033203125, 242.865966796875}}, Typeset`update$$ = 0, 
    Typeset`initDone$$, Typeset`skipInitDone$$ = False}, 
    DynamicBox[Manipulate`ManipulateBoxes[
     1, StandardForm, "Variables" :> {$CellContext`center$$ = {0, 0}}, 
      "ControllerVariables" :> {}, 
      "OtherVariables" :> {
       Typeset`show$$, Typeset`bookmarkList$$, Typeset`bookmarkMode$$, 
        Typeset`animator$$, Typeset`animvar$$, Typeset`name$$, 
        Typeset`specs$$, Typeset`size$$, Typeset`update$$, Typeset`initDone$$,
         Typeset`skipInitDone$$}, "Body" :> Module[{$CellContext`radius$ = Max[
           Norm[{1, 0} - $CellContext`center$$], 
           
           Norm[{-1, 
             0} - $CellContext`center$$]], $CellContext`circle$}, \
$CellContext`circle$ = $CellContext`radius$ {
             Cos[#], 
             Sin[#]} + $CellContext`center$$& ; ParametricPlot[{
           $CellContext`circle$[$CellContext`\[Theta]], 
           $CellContext`joukowski[1][
            $CellContext`circle$[$CellContext`\[Theta]]]}, {$CellContext`\
\[Theta], 0, 2 Pi}, PlotRange -> 2.5, Epilog -> {
            AbsolutePointSize[10], Blue, 
            Point[{1, 0}], 
            Point[{-1, 0}], Red, 
            Circle[{-0.2, 0.2}, 0.08], 
            Circle[{-0.2, 0.2}, 0.05], 
            Circle[{-0.2, 0.2}, 0.02], 
            Line[{{-0.2, 0.1}, {-0.2, 0.3}}], 
            Line[{{-0.3, 0.2}, {-0.1, 0.2}}]}, 
          PlotStyle -> {{Thick, Blue}, {Thick, Red}}, 
          ImageSize -> {480, 480}]], 
      "Specifications" :> {{{$CellContext`center$$, {0, 0}}, Automatic, 
         ControlType -> Locator}}, "Options" :> {}, 
      "DefaultOptions" :> {ControllerLinking -> True}],
     ImageSizeCache->{529.1, {267.9044586181641, 273.6363922119141}},
     SingleEvaluation->True],
    Deinitialization:>None,
    DynamicModuleValues:>{},
    Initialization:>({$CellContext`joukowski[
         Pattern[$CellContext`c, 
          Blank[]]][{
          Pattern[$CellContext`x, 
           Blank[]], 
          Pattern[$CellContext`y, 
           
           Blank[]]}] := {$CellContext`x, $CellContext`y} + \
($CellContext`c^2/($CellContext`x^2 + $CellContext`y^2)) {$CellContext`x, \
-$CellContext`y}, Attributes[PlotRange] = {ReadProtected}}; 
     Typeset`initDone$$ = True),
    SynchronousInitialization->True,
    UndoTrackedVariables:>{Typeset`show$$, Typeset`bookmarkMode$$},
    UnsavedVariables:>{Typeset`initDone$$},
    UntrackedVariables:>{Typeset`size$$}], "Manipulate",
   Deployed->True,
   StripOnInput->False],
  Manipulate`InterpretManipulate[1]]], "Output",
 TaggingRules->{},
