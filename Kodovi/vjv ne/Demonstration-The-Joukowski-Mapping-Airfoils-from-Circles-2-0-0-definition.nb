Cell["The Joukowski Mapping: Airfoils from Circles", "Title",
 TaggingRules->{},
 CellChangeTimes->{{3.6575413683484073`*^9, 3.6575413847064075`*^9}, {
  3.6580254495891523`*^9, 3.658025450444579*^9}},
