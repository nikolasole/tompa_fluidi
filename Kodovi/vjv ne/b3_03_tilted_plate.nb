Notebook[{
 Cell["(* Tilted plate: streamlines from complex potential (6.21) *)\n\
phi = 15 Degree;\n\
base = {Frame -> True, Axes -> False, FrameStyle -> Black, Background -> White, ImageSize -> 800};\n\
W[z_] := Exp[I phi] (z Cos[phi] - I Sin[phi] Sqrt[z^2 - Exp[-2 I phi]]);\n\
F[z_] := D[W[z], z];\n\
psi[x_, y_] := Im[W[x + I y]];\n\
u[x_, y_] := Re[F[x + I y]]; v[x_, y_] := -Im[F[x + I y]];\n\
(* exclude a thin tube around the segment between +/- Exp[-I phi] *)\n\
segA = ReIm[Exp[-I phi]]; segB = ReIm[-Exp[-I phi]];\n\
distToSeg[{x_, y_}] := Module[{vx = segB[[1]] - segA[[1]], vy = segB[[2]] - segA[[2]], t, px, py},\n\
  px = x - segA[[1]]; py = y - segA[[2]];\n\
  t = (px vx + py vy)/(vx^2 + vy^2); t = Clip[t, {0, 1}];\n\
  Sqrt[(px - t vx)^2 + (py - t vy)^2]\n\
];\n\
contours = ContourPlot[psi[x, y], {x, -3, 3}, {y, -3, 3},\n\
  Contours -> 18, ContourStyle -> Directive[Blue, Thick], ContourShading -> False,\n\
  RegionFunction -> Function[{x, y}, distToSeg[{x, y}] > 0.03]];\n\
arrows = StreamPlot[{u[x, y], v[x, y]}, {x, -3, 3}, {y, -3, 3},\n\
  StreamStyle -> Directive[Black, Arrowheads[0.02]], StreamPoints -> 10,\n\
  StreamScale -> {Small, Scaled[0.4], None},\n\
  RegionFunction -> Function[{x, y}, distToSeg[{x, y}] > 0.03]];\n\
plate = Graphics[{Black, Thick, Line[{segA, segB}]}];\n\
Show[contours, arrows, plate, Evaluate@base]\n", "Input"]
}]