Notebook[{
 Cell["(* Example 5.1 - Translation z -> z + beta *)\n\
beta = 0.5 + 0.3 I;\n\
base = {Frame -> True, Axes -> False, FrameStyle -> Black, Background -> White, ImageSize -> 800};\n\
g[z_] := z + beta;\n\
map[z_] := {Re[g[z]], Im[g[z]]};\n\
grid = Show[\n\
  Table[ParametricPlot[map[x0 + I t], {t, -1, 1}, PlotStyle -> Black], {x0, -1, 1, 0.2}],\n\
  Table[ParametricPlot[map[t + I y0], {t, -1, 1}, PlotStyle -> Black], {y0, -1, 1, 0.2}]\n\
];\n\
Show[grid, Evaluate@base]\n", "Input"]
}]