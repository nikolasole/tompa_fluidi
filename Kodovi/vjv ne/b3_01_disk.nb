Notebook[{
 Cell["(* Disk flow: streamlines = contours of psi, arrows from velocity *)\n\
U = 1; R = 1;\n\
base = {Frame -> True, Axes -> False, FrameStyle -> Black, Background -> White, ImageSize -> 800};\n\
W[z_] := U (z + R^2/z);\n\
F[z_] := D[W[z], z];\n\
psi[x_, y_] := Im[W[x + I y]];\n\
u[x_, y_] := Re[F[x + I y]]; v[x_, y_] := -Im[F[x + I y]];\n\
contours = ContourPlot[psi[x, y], {x, -3, 3}, {y, -3, 3},\n\
  Contours -> 18, ContourStyle -> Directive[Blue, Thick], ContourShading -> False,\n\
  RegionFunction -> Function[{x, y}, x^2 + y^2 >= R^2 + 0.02]];\n\
arrows = StreamPlot[{u[x, y], v[x, y]}, {x, -3, 3}, {y, -3, 3},\n\
  StreamStyle -> Directive[Black, Arrowheads[0.02]], StreamPoints -> 12,\n\
  StreamScale -> {Small, Scaled[0.4], None},\n\
  RegionFunction -> Function[{x, y}, x^2 + y^2 >= R^2 + 0.02]];\n\
disk = Graphics[{GrayLevel[0.85], Disk[{0, 0}, R], Black, Thick, Circle[{0, 0}, R]}];\n\
Show[contours, arrows, disk, Evaluate@base]\n", "Input"]
}]