Notebook[{
 Cell["(* Example 6.5 - Flow around exterior corner: W = (i z)^(2/3) *)\n\
base = {Frame -> True, Axes -> False, FrameStyle -> Black, Background -> White, ImageSize -> 800, PlotRange -> All};\n\
W[z_] := (I z)^(2/3);\n\
F[z_] := D[W[z], z];\n\
u[x_, y_] := Re[F[x + I y]]; v[x_, y_] := -Im[F[x + I y]];\n\
StreamPlot[{u[x, y], v[x, y]}, {x, -2, 2}, {y, -2, 2},\n\
 StreamStyle -> Directive[Black, Arrowheads[0.02]], StreamPoints -> Fine,\n\
 StreamScale -> {Small, Scaled[0.6], None}, Evaluate@base]\n", "Input"]
}]