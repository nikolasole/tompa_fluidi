Notebook[{
 Cell["(* Primjer 2.6.10 – Aeroprofil (Joukowski + tok oko cilindra) *)\n\
U = 1; R = 1; Γ = 2; c0 = -0.1 + 0.2 I;\n\
base = {Frame -> True, Axes -> False, FrameStyle -> Black, Background -> White, ImageSize -> 800, PlotRange -> All};\n\
ζ[z_] := z - c0;\n\
w[z_] := z + 1/z;\n\
zfromw[w_] := (w + Sqrt[w^2 - 4])/2;\n\
Fz[z_] := U (1 - R^2/ζ[z]^2) - I Γ/(2 Pi ζ[z]);\n\
Fw[w_] := Module[{z = zfromw[w]}, Fz[z]/(1 - 1/z^2)];\n\
u[x_, y_] := Re[Fw[x + I y]]; v[x_, y_] := -Im[Fw[x + I y]];\n\
flow = StreamPlot[{u[x, y], v[x, y]}, {x, -3, 3}, {y, -3, 3},\n\
 StreamStyle -> Directive[Black, Arrowheads[0.02]], StreamPoints -> Fine,\n\
 StreamScale -> {Small, Scaled[0.6], None},\n\
 RegionFunction -> Function[{x, y}, Abs[ζ[zfromw[x + I y]]] >= R + 0.02]];\n\
airfoil = ParametricPlot[Evaluate[w[c0 + R Exp[I t]]], {t, 0, 2 Pi},\n\
 PlotStyle -> Directive[Black, Thick]];\n\
Show[flow, airfoil, Evaluate@base]\n", "Input"]
}]