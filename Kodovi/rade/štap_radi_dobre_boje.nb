  RowBox[{
   RowBox[{
    RowBox[{"baseOptions", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Frame", "->", "True"}], ",", 
       RowBox[{"Axes", "->", "False"}], ",", 
       RowBox[{"FrameStyle", "->", "Black"}], ",", 
       RowBox[{"Background", "->", "White"}], ",", 
       RowBox[{"ImageSize", "->", "400"}], ",", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"Smanjeno", " ", "za", " ", "GraphicsGrid"}], ",", 
         RowBox[{"original", " ", "je", " ", "800"}]}], "*)"}], 
       RowBox[{"PlotRange", "->", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "2"}], ",", "2"}], "}"}]}], "}"}]}]}], "}"}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"1.", " ", "Inverz", " ", 
     RowBox[{"Joukowskog", ":", 
      RowBox[{
      "Mapira", " ", "ravninu", " ", "plo\[CHacek]e", " ", "natrag", " ", 
       "na", " ", "krug"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"toKrug", "[", "zeta_", "]"}], ":=", 
     RowBox[{"zeta", "+", 
      RowBox[{
       RowBox[{"Sqrt", "[", 
        RowBox[{"zeta", "-", "1"}], "]"}], " ", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"zeta", "+", "1"}], "]"}]}]}]}], ";"}], "\[IndentingNewLine]",
    "\n", 
   RowBox[{"(*", 
    RowBox[{
    "2.", " ", "Potencijal", " ", "za", " ", "kosi", " ", "tok", " ", "oko", " ",
      "kruga", " ", "pod", " ", "kutom", " ", "phi"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Wkrug", "[", 
      RowBox[{"z_", ",", "phi_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"z", "*", 
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", "I"}], " ", "phi"}], "]"}]}], "+", 
      RowBox[{"1", "/", 
       RowBox[{"(", 
        RowBox[{"z", "*", 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{"-", "I"}], " ", "phi"}], "]"}]}], ")"}]}]}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "3.", " ", "Kompleksna", " ", "brzina", " ", "u", " ", "ravnini", " ", 
     "plo\[CHacek]e"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"ComplexVelocity", "[", 
      RowBox[{"zeta_", ",", "phi_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "z", "}"}], ",", 
       RowBox[{
        RowBox[{"z", "=", 
         RowBox[{"toKrug", "[", "zeta", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"Conjugate", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Exp", "[", 
             RowBox[{
              RowBox[{"-", "I"}], " ", "phi"}], "]"}], "-", 
            RowBox[{
             RowBox[{"Exp", "[", 
              RowBox[{"I", " ", "phi"}], "]"}], "/", 
             RowBox[{"z", "^", "2"}]}]}], ")"}], "/", 
          RowBox[{"(", 
           RowBox[{"1", "-", 
            RowBox[{"1", "/", 
             RowBox[{"z", "^", "2"}]}]}], ")"}]}], "]"}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Kutovi", " ", "napada"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"angles", "=", 
     RowBox[{"{", 
      RowBox[{"0", ",", 
       RowBox[{"15", " ", "Degree"}], ",", 
       RowBox[{"30", " ", "Degree"}]}], "}"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"plots", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"StreamPlot", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Re", "[", 
            RowBox[{"ComplexVelocity", "[", 
             RowBox[{
              RowBox[{"x", "+", 
               RowBox[{"I", " ", "y"}]}], ",", "phi"}], "]"}], "]"}], ",", 
           RowBox[{"Im", "[", 
            RowBox[{"ComplexVelocity", "[", 
             RowBox[{
              RowBox[{"x", "+", 
               RowBox[{"I", " ", "y"}]}], ",", "phi"}], "]"}], "]"}]}], "}"}],
          ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", 
           RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"y", ",", 
           RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", 
         RowBox[{"(*", 
          RowBox[{
           RowBox[{
           "Stil", " ", "strelica", " ", "preuzet", " ", "iz", " ", 
            "datoteka", " ", "p01"}], ",", "p02", ",", "p03"}], "*)"}], 
         RowBox[{"StreamStyle", "->", 
          RowBox[{"Directive", "[", 
           RowBox[{"Black", ",", 
            RowBox[{"Arrowheads", "[", "0.02", "]"}]}], "]"}]}], ",", 
         RowBox[{"StreamPoints", "->", "Fine"}], ",", 
         RowBox[{"StreamScale", "->", 
          RowBox[{"{", 
           RowBox[{"Small", ",", 
            RowBox[{"Scaled", "[", "0.6", "]"}], ",", "None"}], "}"}]}], ",", 
         
         RowBox[{"RegionFunction", "->", 
          RowBox[{"Function", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"x", ",", "y"}], "}"}], ",", 
            RowBox[{"Not", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"Abs", "[", "y", "]"}], "<", "0.03"}], "&&", 
              RowBox[{
               RowBox[{"Abs", "[", "x", "]"}], "<", "1.05"}]}], "]"}]}], 
           "]"}]}], ",", 
         RowBox[{"AspectRatio", "->", "Automatic"}], ",", 
         RowBox[{"PlotLabel", "->", 
          RowBox[{"Style", "[", 
           RowBox[{
            RowBox[{"Row", "[", 
             RowBox[{"{", 
              RowBox[{"\"\<Kut napada = \>\"", ",", 
               RowBox[{"phi", "/", "Degree"}], ",", "\"\<\[Degree]\>\""}], 
              "}"}], "]"}], ",", "Black", ",", "14"}], "]"}]}], ",", 
