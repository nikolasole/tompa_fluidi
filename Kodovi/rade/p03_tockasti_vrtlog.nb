Notebook[{
 Cell["(* Primjer 2.6.3 – Točkasti vrtlog *)\n\
Γ = 2;\n\
base = {Frame -> True, Axes -> False, FrameStyle -> Black, Background -> White, ImageSize -> 800, PlotRange -> All};\n\
u[x_, y_] := -(Γ/(2 Pi)) (y/(x^2 + y^2));\n\
v[x_, y_] :=  (Γ/(2 Pi)) (x/(x^2 + y^2));\n\
StreamPlot[{u[x, y], v[x, y]}, {x, -3, 3}, {y, -3, 3},\n\
 StreamStyle -> Directive[Black, Arrowheads[0.02]], StreamPoints -> Fine,\n\
 StreamScale -> {Small, Scaled[0.6], None},\n\
 RegionFunction -> Function[{x, y}, x^2 + y^2 >= 0.05],\n\
 Evaluate@base]\n", "Input"]
}]